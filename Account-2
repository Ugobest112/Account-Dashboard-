                        <button class="btn btn-primary" onclick="addPaymentMethod()">
                            <i class="fas fa-plus"></i>
                            Add Payment Method
                        </button>
                    </div>
                </div>
                
                <div class="payment-methods">
                    ${sampleData.paymentMethods.map(method => `
                        <div class="payment-card">
                            <div class="payment-details">
                                <div class="payment-icon">
                                    <i class="fab fa-cc-${method.type}"></i>
                                </div>
                                <div class="payment-info">
                                    <h4>${method.type.charAt(0).toUpperCase() + method.type.slice(1)} ending in ${method.last4}</h4>
                                    <p>Expires ${method.expiry} ${method.default ? '• Default Payment Method' : ''}</p>
                                    ${method.expired ? '<div class="payment-expired"><i class="fas fa-exclamation-circle"></i> Expired</div>' : ''}
                                </div>
                            </div>
                            <div class="table-actions">
                                ${method.default ? '' : '<button class="action-btn view" onclick="setDefaultPayment(\'' + method.type + '\')">Set as Default</button>'}
                                <button class="action-btn track" onclick="editPaymentMethod('${method.type}')">Edit</button>
                                ${method.default ? '' : '<button class="action-btn track" style="background-color: var(--danger-light); color: var(--danger);" onclick="deletePaymentMethod(\'' + method.type + '\')">Delete</button>'}
                            </div>
                        </div>
                    `).join('')}
                </div>
            `;
        }

