        // Notification button
        notificationBtn.addEventListener('click', () => {
            alert(`You have ${sampleData.notifications.length} notifications:\n\n${sampleData.notifications.map(n => `• ${n.message} (${n.time})`).join('\n')}`);
        });

        // Update notification badge
        function updateNotificationBadge() {
            document.getElementById('notificationCount').textContent = sampleData.notifications.length;
