                <!-- Terms & Conditions -->
                <div style="padding: 20px; background-color: #f9f9f9; border-radius: 8px; margin-top: 30px;">
                    <div class="form-group">
                        <label style="display: flex; align-items: flex-start; gap: 10px;">
                            <input type="checkbox" id="terms-agreement" style="margin-top: 5px;">
                            <span>I agree to the <a href="#" style="color: #0066c0;">Terms & Conditions</a>, <a href="#" style="color: #0066c0;">Privacy Policy</a>, and authorize ShopCart to charge my selected payment method for the total amount shown. I understand that I can return eligible items within 30 days of delivery.</span>
                        </label>
                    </div>
                    
                    <div class="form-group" style="margin-top: 15px;">
                        <label style="display: flex; align-items: center; gap: 10px;">
                            <input type="checkbox" id="newsletter-signup" checked>
