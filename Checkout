    <!-- Order Complete Section -->
    <div class="order-complete" id="order-complete">
        <div class="complete-icon">
            <i class="fas fa-check-circle"></i>
        </div>
        
        <h2 class="complete-title">Thank you for your order!</h2>
        
        <p class="complete-message">
            Your order has been successfully placed and is being processed.
            You will receive an email confirmation shortly with your order details.
        </p>
        
        <div class="order-details">
            <div class="detail-row">
                <span>Order Number:</span>
                <strong>#SC-2023-58742</strong>
            </div>
            
            <div class="detail-row">
                <span>Order Date:</span>
                <span id="complete-date">October 15, 2023</span>
            </div>
            
            <div class="detail-row">
                <span>Estimated Delivery:</span>
                <span id="complete-delivery">October 22-24, 2023</span>
            </div>
            
            <div class="detail-row">
                <span>Total Amount:</span>
                <strong id="complete-total">$2,350.15</strong>
            </div>
            
            <div class="detail-row">
                <span>Payment Method:</span>
                <span id="complete-payment">Visa ending in 1234</span>
            </div>
        </div>
        
        <div style="display: flex; gap: 15px; justify-content: center; margin-top: 30px;">
            <button class="btn-back" onclick="continueShopping()">
                <i class="fas fa-shopping-cart"></i>
                Continue Shopping
            </button>
            
            <button class="btn-continue" onclick="viewOrderDetails()">
                <i class="fas fa-eye"></i>
                View Order Details
            </button>
        </div>
    </div>
    
    <script>
        // Checkout State
        const checkoutState = {
            currentStep: 1,
            totalSteps: 3,
            shipping: {
                name: "John Smith",
                address: "123 Main Street, Apt 4B, New York, NY 10001, United States",
                method: "Standard Shipping (5-7 business days)",
                cost: 9.99
            },
            payment: {
                method: "Credit Card",
                cardType: "Visa",
                lastFour: "1234",
                expiry: "12/2025"
            },
            order: {
                subtotal: 2189.96,
                shipping: 9.99,
                tax: 175.20,
                discount: 25.00,
                total: 2350.15
            }
        };
        
        // DOM Elements
        const progressBar = document.getElementById('progress-bar');
        const step1 = document.getElementById('step-1');
        const step2 = document.getElementById('step-2');
        const step3 = document.getElementById('step-3');
        const shippingSection = document.getElementById('shipping-section');
        const paymentSection = document.getElementById('payment-section');
        const reviewSection = document.getElementById('review-section');
        const backButton = document.getElementById('back-button');
        const continueButton = document.getElementById('continue-button');
        const orderComplete = document.getElementById('order-complete');// Initialize
        updateProgressBar();
        updateContinueButton();
        
        // Step Navigation
        function goToStep(step) {
            checkoutState.currentStep = step;
            updateProgressBar();
            updateSections();
            updateContinueButton();
            updateBackButton();
        }
        
        function nextStep() {
            if (checkoutState.currentStep < checkoutState.totalSteps) {
                // Validate current step before proceeding
                if (validateCurrentStep()) {
                    checkoutState.currentStep++;
                    updateProgressBar();
                    updateSections();
                    updateContinueButton();
                    updateBackButton();
                    
                    // If we've reached the final step, show order complete
                    if (checkoutState.currentStep === checkoutState.totalSteps) {
                        // Wait for order placement then show complete
                        setTimeout(() => {
                            completeOrder();
                        }, 1000);
                    }
                }
            }
        }
        
        function prevStep() {
            if (checkoutState.currentStep > 1) {
                checkoutState.currentStep--;
                updateProgressBar();
                updateSections();
                updateContinueButton();
                updateBackButton();
            }
        }
        
        // Update progress bar
        function updateProgressBar() {
            const progressPercentage = ((checkoutState.currentStep - 1) / (checkoutState.totalSteps - 1)) * 100;
            progressBar.style.width = `${progressPercentage}%`;
            
            // Update step classes
            step1.classList.remove('active', 'completed');
            step2.classList.remove('active', 'completed');
            step3.classList.remove('active', 'completed');
            
            // Set current step as active
            document.getElementById(`step-${checkoutState.currentStep}`).classList.add('active');
            
            // Set previous steps as completed
            for (let i = 1; i < checkoutState.currentStep; i++) {
                document.getElementById(`step-${i}`).classList.add('completed');
            }
        }
        
        // Update sections visibility
        function updateSections() {
            // Hide all sections
            shippingSection.classList.remove('active');
            paymentSection.classList.remove('active');
            reviewSection.classList.remove('active');
            
            // Show current section
            if (checkoutState.currentStep === 1) {
                shippingSection.classList.add('active');
            } else if (checkoutState.currentStep === 2) {
                paymentSection.classList.add('active');
            } else if (checkoutState.currentStep === 3) {
                updateReviewSection();
                reviewSection.classList.add('active');
            }
        }
        
        // Update continue button text
        function updateContinueButton() {
            const buttonTexts = {
                1: "Continue to Payment",
                2: "Review Order",
                3: "Place Order"
            };
            
            continueButton.innerHTML = `
                ${buttonTexts[checkoutState.currentStep]}
                <i class="fas fa-arrow-right"></i>
            `;
            
            // Disable button on review step if terms not agreed
            if (checkoutState.currentStep === 3) {
                continueButton.disabled = !document.getElementById('terms-agreement')?.checked;
            } else {
                continueButton.disabled = false;
            }
        }
        
        // Update back button visibility
        function updateBackButton() {
            if (checkoutState.currentStep > 1) {
                backButton.style.display = 'flex';
            } else {
                backButton.style.display = 'none';
            }
        }
        
        // Validate current step
        function validateCurrentStep() {
            if (checkoutState.currentStep === 1) {
                // Validate shipping
                const addressSelected = document.querySelector('input[name="address"]:checked');
                const shippingSelected = document.querySelector('input[name="shipping"]:checked');
                
                if (!addressSelected || !shippingSelected) {
                    alert('Please select a shipping address and shipping method.');
                    return false;
                }
                
                // Update shipping info in state
                updateShippingInfo();
                return true;
                
            } else if (checkoutState.currentStep === 2) {
                // Validate payment
                const paymentSelected = document.querySelector('.payment-option.selected');
                
                if (!paymentSelected) {
                    alert('Please select a payment method.');
                    return false;
                }
                
                // Update payment info in state
                updatePaymentInfo();
                return true;
                
            } else if (checkoutState.currentStep === 3) {
                // Validate terms agreement
                const termsAgreed = document.getElementById('terms-agreement').checked;
                
                if (!termsAgreed) {
                    alert('Please agree to the terms and conditions to place your order.');
                    return false;
                }
                
                return true;
            }
            
            return true;
        }
        
        // Update shipping info in state
        function updateShippingInfo() {
            // Get selected address
            const selectedAddress = document.querySelector('.saved-option.selected input[name="address"]');
            if (selectedAddress) {
                const addressOption = selectedAddress.closest('.saved-option');
                const addressText = addressOption.querySelector('.option-address').textContent;
                
                // Extract name from address (first part before comma)
                const name = addressText.split(',')[0];
                checkoutState.shipping.name = name.trim();
                checkoutState.shipping.address = addressText;
            } // Get selected shipping method
            const selectedShipping = document.querySelector('.saved-option.selected input[name="shipping"]');
            if (selectedShipping) {
                const shippingOption = selectedShipping.closest('.saved-option');
                const shippingText = shippingOption.querySelector('.option-address').textContent;
                
                // Extract shipping cost
                const costMatch = shippingText.match(/\$(\d+\.\d+)/);
                if (costMatch) {
                    checkoutState.shipping.cost = parseFloat(costMatch[1]);
                }
                
                checkoutState.shipping.method = shippingText;
            }
            
            // Update summary
            updateOrderSummary();
        }
        
        // Update payment info in state
        function updatePaymentInfo() {
            const selectedPayment = document.querySelector('.payment-option.selected');
            if (selectedPayment) {
                const paymentTitle = selectedPayment.querySelector('.payment-title').textContent;
                checkoutState.payment.method = paymentTitle;
                
                // If credit card, get card details
                if (paymentTitle === 'Credit/Debit Card') {
                    const selectedCard = document.querySelector('.saved-option.selected input[name="card"]');
                    if (selectedCard) {
                        const cardOption = selectedCard.closest('.saved-option');
                        const cardText = cardOption.querySelector('.option-title').textContent;
                        
                        // Extract card info
                        const cardMatch = cardText.match(/(\w+)\s+ending in\s+(\d{4})/);
                        if (cardMatch) {
                            checkoutState.payment.cardType = cardMatch[1];
                            checkoutState.payment.lastFour = cardMatch[2];
                        }
                        
                        const expiryText = cardOption.querySelector('.option-address').textContent;
                        const expiryMatch = expiryText.match(/(\d{2}\/\d{4})/);
                        if (expiryMatch) {
                            checkoutState.payment.expiry = expiryMatch[1];
                        }
                    }
                }
            }
        }
        
        // Update review section with current info
        function updateReviewSection() {
            // Update shipping info
            document.getElementById('review-shipping-name').textContent = checkoutState.shipping.name;
            document.getElementById('review-shipping-address').textContent = checkoutState.shipping.address;
            document.getElementById('review-shipping-method').textContent = `Shipping: ${checkoutState.shipping.method}`;
            
            // Update payment info
            document.getElementById('review-payment-method').textContent = checkoutState.payment.method;
            
            if (checkoutState.payment.method === 'Credit/Debit Card') {
                document.getElementById('review-card-number').textContent = `${checkoutState.payment.cardType} ending in ${checkoutState.payment.lastFour}`;
                document.getElementById('review-card-expiry').textContent = `Expires ${checkoutState.payment.expiry}`;
            } else {
                document.getElementById('review-card-number').textContent = checkoutState.payment.method;
                document.getElementById('review-card-expiry').textContent = '';
            }
        }
        
        // Update order summary
        function updateOrderSummary() {
            // Update shipping cost
            document.getElementById('summary-shipping').textContent = `$${checkoutState.shipping.cost.toFixed(2)}`;
            
            // Recalculate total
            checkoutState.order.total = checkoutState.order.subtotal + checkoutState.shipping.cost + checkoutState.order.tax - checkoutState.order.discount;
            
            // Update display
            document.getElementById('summary-total').textContent = `$${checkoutState.order.total.toFixed(2)}`;
        }
        
        // Complete order
        function completeOrder() {
            // Hide checkout forms and show order complete
            document.querySelector('.checkout-container').style.display = 'none';
            document.querySelector('.checkout-progress').style.display = 'none';
            
            // Update order complete details
            const now = new Date();
            const options = { year: 'numeric', month: 'long', day: 'numeric' };
            document.getElementById('complete-date').textContent = now.toLocaleDateString('en-US', options);
            
            // Set delivery date (5-7 days from now)
            const deliveryDate = new Date(now);
            deliveryDate.setDate(deliveryDate.getDate() + 5);
            const deliveryEndDate = new Date(now);
            deliveryEndDate.setDate(deliveryEndDate.getDate() + 7);
            
            document.getElementById('complete-delivery').textContent = 
                `${deliveryDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}-${deliveryEndDate.getDate()}, ${deliveryEndDate.getFullYear()}`;
            
            document.getElementById('complete-total').textContent = `$${checkoutState.order.total.toFixed(2)}`;
            
            if (checkoutState.payment.method === 'Credit/Debit Card') {
                document.getElementById('complete-payment').textContent = `${checkoutState.payment.cardType} ending in ${checkoutState.payment.lastFour}`;
            } else {
                document.getElementById('complete-payment').textContent = checkoutState.payment.method;
            }
            
            // Show order complete section
            orderComplete.style.display = 'block';
            
            // Update progress step 3
            step3.classList.add('completed');
        }
        
        // Address and Card Forms
        document.getElementById('add-new-address').addEventListener('click', function() {
            document.querySelector('.saved-options').style.display = 'none';
            document.getElementById('new-address-form').style.display = 'block';
        });
        
        document.getElementById('add-new-card').addEventListener('click', function() {
            document.querySelector('#card-details .saved-options').style.display = 'none';
            document.getElementById('new-card-form').style.display = 'block';
        });// Payment method selection
        document.querySelectorAll('.payment-option').forEach(option => {
            option.addEventListener('click', function() {
                // Deselect all
                document.querySelectorAll('.payment-option').forEach(opt => {
                    opt.classList.remove('selected');
                });
                
                // Select clicked
                this.classList.add('selected');
                
                // Show/hide card details
                const paymentMethod = this.querySelector('.payment-title').textContent;
                const cardDetails = document.getElementById('card-details');
                
                if (paymentMethod === 'Credit/Debit Card') {
                    cardDetails.classList.add('active');
                } else {
                    cardDetails.classList.remove('active');
                }
            });
        });
        
        // Terms agreement checkbox
        document.getElementById('terms-agreement')?.addEventListener('change', function() {
            updateContinueButton();
        });
        
        // Discount code
        document.getElementById('summary-apply-btn').addEventListener('click', function() {
            const code = document.getElementById('summary-discount-code').value.trim().toUpperCase();
            
            if (code === 'SAVE25') {
                checkoutState.order.discount = 25.00;
                document.getElementById('summary-discount').textContent = '-$25.00';
                alert('Discount code applied! You saved $25.00.');
            } else if (code === 'FREESHIP') {
                checkoutState.shipping.cost = 0.00;
                document.getElementById('summary-shipping').textContent = '$0.00';
                alert('Discount code applied! Free shipping activated.');
            } else if (code === '') {
                alert('Please enter a discount code.');
                return;
            } else {
                alert('Invalid discount code. Try SAVE25 or FREESHIP.');
                return;
            }
            
            updateOrderSummary();
            document.getElementById('summary-discount-code').value = '';
        });
        
        // Button event listeners
        continueButton.addEventListener('click', nextStep);
        backButton.addEventListener('click', prevStep);
        
        // Order complete actions
        function continueShopping() {
            alert('Redirecting to home page...');
            // In a real app, this would redirect to the home page
        }
        
        function viewOrderDetails() {
            alert('Redirecting to order details page...');
            // In a real app, this would redirect to the order details page
        }
        
        // Initialize with today's date for order complete
        const today = new Date();
        const options = { year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('complete-date').textContent = today.toLocaleDateString('en-US', options);
        
        // Add event listeners to saved options
        document.querySelectorAll('.saved-option input[type="radio"]').forEach(radio => {
            radio.addEventListener('change', function() {
                // Remove selected class from all options
                document.querySelectorAll('.saved-option').forEach(option => {
                    option.classList.remove('selected');
                });
                
                // Add selected class to parent
                this.closest('.saved-option').classList.add('selected');
            });
        });
    </script>
